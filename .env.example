# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# Required: Your OpenRouter API Key
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: AI model to use
# Options: inclusionai/ling-2.6-1t:free, etc.
AI_MODEL=inclusionai/ling-2.6-1t:free

# Optional: Temperature for AI generation (0.0 = deterministic, 1.0 = creative)
AI_TEMPERATURE=0.1

# Optional: Directories to watch (comma-separated, defaults to current directory)
# WATCH_DIRS=./src,./lib,./components

# Optional: Additional file extensions to watch (comma-separated)
# WATCH_EXTENSIONS=.tsx,.ts,.js,.jsx,.java
